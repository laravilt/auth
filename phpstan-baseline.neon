parameters:
    ignoreErrors:
        # Eloquent dynamic properties - these are expected for User models
        -
            message: '#Access to an undefined property.*::\$#'
            paths:
                - src/TwoFactor/*
                - src/Services/*
                - src/Http/Controllers/*
                - src/Providers/*
                - src/Notifications/*

        # Laravel specific type issues
        -
            message: '#Call to an undefined method.*#'
            paths:
                - src/Http/Controllers/*

        # Request dynamic properties
        -
            message: '#Cannot access property \$\w+ on Illuminate\\Http\\Request#'
            paths:
                - src/Http/Controllers/*
